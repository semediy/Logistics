<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Logistiks.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="Resources/Colors.xaml"/>
                <ResourceInclude Source="Resources/Typography.xaml"/>
                <ResourceInclude Source="Resources/Spacing.xaml"/>
                <ResourceInclude Source="Resources/Styles.xaml"/>
                <ResourceInclude Source="Resources/Templates.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>