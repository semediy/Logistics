<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Logistiks.Views.RegisterPage">

    <StackPanel Margin="30" Spacing="10">

        <TextBlock Text="Реєстрація"
                   FontSize="24"/>

        <TextBox PlaceholderText="ПІБ"/>

        <TextBox PlaceholderText="Пароль"/>

        <RadioButton Name="Logist"
                     Content="Логіст"
                     Click="RoleChanged"/>

        <RadioButton Name="Driver"
                     Content="Водій"
                     Click="RoleChanged"/>

        <StackPanel Name="LogistPanel"
                    IsVisible="False">

            <CheckBox Content="Міжнародні перевезення"/>

        </StackPanel>

        <StackPanel Name="DriverPanel"
                    IsVisible="False">

            <CheckBox Content="B"/>
            <CheckBox Content="C"/>
            <CheckBox Content="CE"/>

        </StackPanel>

        <Button Content="Зареєструватися"
                Click="RegisterClick"/>

    </StackPanel>

</UserControl>